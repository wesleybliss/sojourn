{
    "compilerOptions": {
        "noEmit": true,
        "allowJs": false,
        "strict": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true
    }
}
