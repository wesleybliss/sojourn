{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/web.tsbuildinfo",
        "declarationDir": "./node_modules/.cache/dts/web",
        "lib": [
            "ES2023",
            "DOM"
        ],
        "target": "es2017",
        "jsx": "react-jsx",
        "types": [
            "vite/client"
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "plugins": [
        {
            "name": "next"
        }
    ],
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
    ]
}