{
    "name": "sojourn",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:web": "pnpm --filter web dev",
        "dev:api": "pnpm --filter api serve",
        "dev": "pnpm --parallel --stream dev:web dev:api",
        "build": "pnpm --filter @repo/shared build && pnpm --filter @repo/web --filter @repo/api build",
        "validate": "pnpm check && pnpm lint:fix",
        "check": "pnpm -r check",
        "lint": "pnpm -r lint",
        "lint:dry": "pnpm -r lint:dry",
        "lint:fix": "pnpm -r lint:fix",
        "eslint": "pnpm -r eslint",
        "eslint:dry": "pnpm -r eslint:dry",
        "eslint:fix": "pnpm -r eslint:fix",
        "test:web": "pnpm --filter web test",
        "test:api": "pnpm --filter api test",
        "test": "pnpm -r test",
        "install-all": "./bin/install-all.sh",
        "fix:parallel": "pnpm --filter \"*\" --parallel --stream check && pnpm --filter \"*\" --parallel --stream lint:fix",
        "update-shared": "pnpm -r update-shared",
        "db:push": "drizzle-kit push"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.9.1",
        "@typescript-eslint/eslint-plugin": "^8.59.4",
        "@typescript-eslint/parser": "^8.59.4",
        "dotenv": "^17.4.2",
        "dotenv-cli": "^11.0.0",
        "eslint": "^10.4.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-indent-empty-lines": "^2.0.2",
        "eslint-plugin-oxlint": "^1.66.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "globals": "^17.6.0",
        "oxlint": "^1.66.0",
        "stylelint": "^17.12.0",
        "stylelint-config-standard": "^40.0.0",
        "tsx": "^4.22.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.4"
    },
    "dependencies": {
        "drizzle-kit": "1.0.0-beta.22",
        "drizzle-orm": "1.0.0-beta.22"
    }
}
