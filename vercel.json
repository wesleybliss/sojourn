{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "buildCommand": "pnpm build",
    "outputDirectory": "apps/web/dist",
    "installCommand": "pnpm install",
    "functions": {
        "api/*.js": {
            "maxDuration": 60
        },
        "api/**/*.js": {
            "maxDuration": 60
        }
    },
    "fluid": true,
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "github": {
        "silent": true
    }
}
