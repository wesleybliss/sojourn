{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/shared.tsbuildinfo",
        "declarationDir": "./node_modules/.cache/dts/shared",
        "lib": ["es2015", "DOM"],
        "target": "ES2022",
        "types": ["node"],
        "noEmit": false,
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@repo/shared": ["./src/index.ts"],
            "@repo/shared/*": ["./src/*"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "**/*",
        "**/*x"
    ]
}
