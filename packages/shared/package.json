{
    "name": "@repo/shared",
    "version": "0.0.1",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "build": "tsc -b && tsc-alias -p tsconfig.json",
        "check1": "pnpm tsc -p tsconfig.typecheck.json --skipLibCheck",
        "check": "pnpm tsc -p tsconfig.json --skipLibCheck",
        "lint": "oxlint && eslint .",
        "lint:dry": "oxlint && eslint --fix-dry-run .",
        "lint:fix": "oxlint --fix && eslint --fix .",
        "eslint": "eslint .",
        "eslint:dry": "eslint --fix-dry-run .",
        "eslint:fix": "eslint --fix .",
        "test": "vitest"
    },
    "exports": {
        "./*": {
            "types": "./src/*.ts",
            "default": "./src/*.ts"
        },
        "./types": {
            "types": "./dist/types/index.ts",
            "default": "./dist/types/index.ts"
        },
        "./constants": {
            "types": "./dist/constants/index.ts",
            "default": "./dist/constants/index.ts"
        },
        "./utils": {
            "types": "./dist/utils/index.ts",
            "default": "./dist/utils/index.ts"
        },
        "./errors": {
            "types": "./dist/errors/index.ts",
            "default": "./dist/errors/index.ts"
        },
        "./db": {
            "types": "./dist/db/index.ts",
            "default": "./dist/db/index.ts"
        },
        "./firebase": {
            "types": "./dist/firebase/index.ts",
            "default": "./dist/firebase/index.ts"
        }
    },
    "dependencies": {
        "@forminator/react-wire": "^0.7.0",
        "@libsql/client": "^0.17.3",
        "@vercel/blob": "^2.4.0",
        "bcryptjs": "^3.0.3",
        "clsx": "^2.1.1",
        "dayjs": "^1.11.20",
        "firebase": "^12.13.0",
        "firebase-admin": "^13.10.0",
        "nanoid": "^5.1.11",
        "next": "16.2.6",
        "react-wire-persisted": "^3.1.0",
        "tailwind-merge": "^3.6.0"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "@types/react": "19.2.14",
        "@types/react-dom": "^19.2.3",
        "vite": "^8.0.14"
    }
}
