{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/api.tsbuildinfo",
        "declarationDir": "../../node_modules/.cache/dts/api",
        "lib": ["ES2023"],
        "composite": true,
        "noEmit": false,
        "emitDeclarationOnly": true,
        "allowJs": false,
        "target": "ES2023",
        "esModuleInterop": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "outDir": "dist",
        "paths": {
            "@/*": ["./src/*"],
            "@api/*": ["./api/*"],
            "@repo/shared": ["../../packages/shared/src/index.ts"],
            "@repo/shared/*": ["../../packages/shared/src/*"]
        },
        "types": ["node"]
    },
    "references": [
        { "path": "../../packages/shared" }
    ],
    "include": ["src", "api", "test"],
    "exclude": ["node_modules", "task/**"]
}
