{
    "name": "@repo/api",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "imports": {
        "#api/*": "./api/*.ts",
        "#handlers/*": "./src/handlers/*.ts"
    },
    "scripts": {
        "dev": "nodemon",
        "start": "dotenv -e ../../.env -- tsx api/index.ts",
        "build": "node build.js",
        "check": "pnpm tsc --noEmit --skipLibCheck",
        "lint": "oxlint && eslint .",
        "lint:dry": "oxlint && eslint --fix-dry-run .",
        "lint:fix": "oxlint --fix && eslint --fix .",
        "eslint": "eslint .",
        "eslint:dry": "eslint --fix-dry-run .",
        "eslint:fix": "eslint --fix .",
        "test": "vitest",
        "db:pull": "drizzle-kit pull",
        "db:push": "drizzle-kit push"
    },
    "dependencies": {
        "@repo/shared": "workspace:*",
        "@vercel/functions": "^3.4.3",
        "ajv": "^8.20.0",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dayjs": "^1.11.20",
        "drizzle-kit": "1.0.0-beta.22",
        "drizzle-orm": "1.0.0-beta.22",
        "express": "^4.18.0",
        "nanoid": "^5.1.11",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.3.3",
        "@types/papaparse": "^5.5.2",
        "@types/supertest": "^7.2.0",
        "@vercel/node": "^5.7.0",
        "@vitest/ui": "^4.1.8",
        "dotenv": "^17.4.0",
        "esbuild": "^0.28.0",
        "eslint": "^10.1.0",
        "eslint-plugin-indent-empty-lines": "^2.0.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "nodemon": "^3.1.14",
        "oxlint": "^1.59.0",
        "supertest": "^7.2.2",
        "tsc-alias": "^1.8.16",
        "typescript": "^6.0.3",
        "vite": "^8.0.8",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.7"
    }
}
