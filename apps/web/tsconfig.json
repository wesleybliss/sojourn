{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/web.tsbuildinfo",
        "declarationDir": "./node_modules/.cache/dts/web",
        "lib": [
            "ES2023",
            "DOM"
        ],
        "target": "es2017",
        "jsx": "react-jsx",
        "types": [
            "vite/client"
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@repo/shared/*": [
                "../../packages/shared/src/*.ts"
            ],
            "@repo/shared": [
                "../../packages/shared/src/index.ts"
            ]
        }
    },
    "plugins": [
        {
            "name": "next"
        }
    ],
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
    ],
    "references": [
        { "path": "../../packages/shared" }
    ]
}
