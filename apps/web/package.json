    "build": "next build",
    "start": "next start",
    "db:push": "npx drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "pnpm lint:js && pnpm lint:css",
    "lint:fix": "pnpm lint:js:fix && pnpm lint:css:fix",
    "lint:js": "eslint src",
    "lint:js:dry": "eslint --fix-dry-run src",
    "lint:js:fix": "eslint --fix src",
    "lint:js:fix:one": "eslint --fix",
    "lint:css": "stylelint --rd --risd --cache 'src/**/*.css'",
    "lint:css:fix": "stylelint --rd --risd --cache --fix 'src/**/*.css'",
    "db:dump": "turso db shell trip-planner .dump > backups/dump_`ts`.sql",
    "db:restore": "echo 'turso db shell trip-planner < backups/dump-.sql'",
    "db:seed": "turso db shell trip-planner < backups/seed.sql"
