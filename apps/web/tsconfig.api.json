{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/api.tsbuildinfo",
        "declarationDir": "./node_modules/.cache/dts/api",
        "composite": true,
        "target": "ES2022",
        "lib": ["ES2023", "DOM"],
        "types": ["node"],
        "paths": {
            "@/*": ["./src/*"],
            "@repo/shared/*": ["../../packages/shared/src/*"],
            "@repo/shared": ["../../packages/shared/src/index.ts"]
        }
    },
    "include": [
        "src/app/api/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "src/**/*.tsx"
    ],
    "references": [{ "path": "../../packages/shared" }]
}
