{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/api.tsbuildinfo",
        "declarationDir": "./node_modules/.cache/dts/api",
        "lib": ["es2015"],
        "target": "ES2022",
        "types": [],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@repo/shared/*": [
                "../../packages/shared/src/*"
            ],
            "@repo/shared": [
                "../../packages/shared/src/index.ts"
            ]
        }
    },
    "include": [
        "src/app/api/**/*.ts",
        "src/app/api/**/*.tsx",
        "src/app/api/**/*",
        "src/app/api/**/*x"
    ],
    "references": [
        { "path": "../../packages/shared" }
    ]
}
